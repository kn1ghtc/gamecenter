            "defend"
          ]
        },
        "attack": {
          "animation": "attack",
          "transitions": [
            "neutral",
            "hit"
          ]
        },
        "defend": {
          "animation": "defend",
          "transitions": [
            "neutral",
            "hit"
          ]
        },
        "hit": {
          "animation": "hit",
          "transitions": [
            "neutral",
            "victory"
          ]
        }
      },
      "current_state": "neutral"
    },
    "blend_parameters": {
      "combat_intensity": 0.0,
      "damage_taken": 0.0
    },
    "active_animations": [
      "idle"
    ]
  },
  "fullbody": {
    "name": "FullBody",
    "root_node": {
      "type": "layered_blend",
      "layers": [
        {
