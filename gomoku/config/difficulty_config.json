      "use_killer_moves": true,
      "use_history_table": true,
      "transposition_table_size": 1000000,
      "candidate_moves_count": 15,
      "description": "适合高手对战，搜索深度7层+迭代加深，最强实力"
    },
    
    "expert": {
      "name": "专家",
      "display_name": "专家 (D9+)",
      "search_depth": 9,
      "time_limit": 15.0,
      "use_iterative_deepening": true,
      "use_killer_moves": true,
      "use_history_table": true,
      "transposition_table_size": 2000000,
      "candidate_moves_count": 20,
      "description": "超高难度，搜索深度9层+迭代加深，需要强劲硬件"
    }
  },
  
  "phase2_optimizations": {
    "_comment": "Phase 2高级优化参数配置 - 激进设置提升性能",
    
    "late_move_reduction": {
      "enabled": false,
      "min_depth": 3,
      "min_move_index": 3,
      "reduction_amount": 1,
      "max_reduction_depth": 2,
      "description": "后期着法深度削减 (暂时禁用测试)"
    },
    
    "null_move_pruning": {
      "enabled": false,
      "min_depth": 3,
      "R_value": 3,
      "adaptive_R": true,
      "min_moves_played": 3,
      "description": "空着剪枝 (暂时禁用测试)"
    },
    
    "incremental_evaluation": {
      "enabled": true,
      "cache_line_scores": true,
      "description": "增量评估，缓存线路评分"
    },
    
    "aspiration_windows": {
      "enabled": true,
      "initial_window": 50,
      "window_growth_factor": 2,
      "description": "期望窗口搜索"
    }
  },
  
  "cpp_engine": {
    "_comment": "C++引擎特定配置",
    "transposition_table_size": 2000000,
    "use_avx2": true,
    "thread_count": 1,
    "description": "C++引擎使用2M置换表"
