      "use_history_table": false,
      "transposition_table_size": 100000,
      "candidate_moves_count": 10,
      "description": "适合初学者，搜索深度3层，响应快速"
    },
    
    "medium": {
      "name": "中等",
      "display_name": "中等 (D5)",
      "search_depth": 5,
      "time_limit": 5.0,
      "use_iterative_deepening": false,
      "use_killer_moves": true,
      "use_history_table": true,
      "transposition_table_size": 500000,
      "candidate_moves_count": 12,
      "description": "适合中级玩家，搜索深度5层，平衡性能与实力"
    },
    
    "hard": {
      "name": "困难",
      "display_name": "困难 (D7+)",
      "search_depth": 7,
      "time_limit": 10.0,
